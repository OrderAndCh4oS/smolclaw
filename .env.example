# Required: Your OpenAI API key (also used for embeddings with Anthropic)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# Optional: Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Optional: Override default models
# Use claude-* models for Anthropic, anything else for OpenAI
COMPLETION_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional: OpenTelemetry tracing (Jaeger, Langfuse, etc.)
# Start Jaeger: docker run -d --name jaeger -p 16686:16686 -p 4318:4318 jaegertracing/all-in-one:latest
# View traces: http://localhost:16686
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
